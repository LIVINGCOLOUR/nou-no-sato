flowchart TD
  %% Nou no Sato Phase 1 screen transition priority
  %% Thick solid lines: Phase 1 Core. Dotted lines: Inline substitute or excluded / not planned.

  Home["S01 ホーム / ランディング<br/>Phase 1 Core"]

  subgraph Core["A. 最初に作る画面 / Phase 1 Core"]
    Members["S02 仲間を探す一覧"]
    Events["S04 イベント一覧<br/>運営登録イベント"]
    EventDetail["S05 イベント詳細"]
    Learn["S06 農法を学ぶ一覧"]
    MethodDetail["S07 農法詳細"]
    Notes["S08 畑ノート一覧<br/>基本非公開"]
    NoteCreate["S09 畑ノート作成・編集"]
    NativeMap["S11 在来種マップ"]
    NativeDetail["S12 在来種詳細"]
    MyPage["S13 マイページ"]
  end

  subgraph Inline["B. 初期は同一画面内で代替 / Inline or Card Expand"]
    MemberInline["S03相当<br/>仲間プロフィールは一覧カード展開"]
    NoteInline["S10相当<br/>畑ノート詳細は一覧カード + 編集画面で代替"]
    SettingsInline["S14相当<br/>公開範囲説明はマイページ内カード"]
  end

  subgraph Excluded["C. 除外 / Not planned"]
    Trouble["困りごとから探す<br/>作らない"]
    Conditional["条件付き相談<br/>作らない"]
    QA["Q&A<br/>作らない"]
    Safety["通報・ブロック<br/>作らない"]
    Seasonal["季節チャレンジ<br/>作らない"]
    VirtualFarm["仮想畑<br/>作らない"]
  end

  Home ==> Members
  Home ==> Events
  Home ==> Learn
  Home ==> Notes
  Home ==> NativeMap
  Home ==> MyPage

  Members -. "カード展開で代替" .-> MemberInline
  Members ==> Events
  Members ==> EventDetail

  Events ==> EventDetail
  EventDetail ==> MyPage

  Learn ==> MethodDetail
  MethodDetail ==> Notes
  MethodDetail ==> NoteCreate

  Notes ==> NoteCreate
  Notes -. "カード表示で代替" .-> NoteInline
  Notes ==> MyPage

  NativeMap ==> NativeDetail
  NativeDetail ==> NativeMap

  MyPage ==> Notes
  MyPage ==> Events
  MyPage -. "説明カードで代替" .-> SettingsInline

  Home -. "除外: 作らない" .-> Trouble
  Home -. "除外: 作らない" .-> Conditional
  Home -. "除外: 作らない" .-> QA
  QA -. "除外: 作らない" .-> Safety
  Notes -. "除外: 作らない" .-> Seasonal
  Notes -. "除外: 作らない" .-> VirtualFarm

  classDef home fill:#e4f3d8,stroke:#1f6b2b,stroke-width:4px,color:#173f1b;
  classDef core fill:#eef8e7,stroke:#2e7d32,stroke-width:3px,color:#173f1b;
  classDef privacy fill:#fff7e8,stroke:#f59a23,stroke-width:3px,color:#5f3e16;
  classDef inline fill:#f8fbf3,stroke:#6f9e4e,stroke-width:2px,stroke-dasharray:6 4,color:#344d24;
  classDef excluded fill:#f4f1eb,stroke:#9b8a74,stroke-width:2px,stroke-dasharray:5 5,color:#5d5142;

  class Home home;
  class Members,Events,EventDetail,Learn,MethodDetail,NativeMap,NativeDetail,MyPage core;
  class Notes,NoteCreate privacy;
  class MemberInline,NoteInline,SettingsInline inline;
  class Trouble,Conditional,QA,Safety,Seasonal,VirtualFarm excluded;